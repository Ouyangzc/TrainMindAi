# ===== 应用 =====
APP_ENV=dev
APP_NAME=trainmind-ai-service
LOG_LEVEL=INFO

# ===== 内部鉴权（与 RuoYi 业务后端共享的强随机串）=====
INTERNAL_TOKEN=change-me-to-a-strong-random-secret

# ===== 数据库（与 RuoYi 共享实例，独立 ai schema）=====
DATABASE_URL=postgresql+asyncpg://postgres:123456@localhost:5432/ruoyi
DB_SCHEMA=ai
DB_ECHO=false

# ===== Redis（与 RuoYi 的 db0 隔离，AI 用 db1）=====
REDIS_URL=redis://localhost:6379/1

# ===== 对象存储 MinIO =====
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=kb-docs
MINIO_SECURE=false

# ===== 向量库 =====
VECTOR_STORE=pgvector
QDRANT_URL=http://localhost:6333

# ===== 模型网关（OpenAI 兼容；LLM 与 Embedding base_url 分离）=====
LLM_BASE_URL=https://api.vendor.com/v1
LLM_API_KEY=
LLM_MODEL=

EMBEDDING_BASE_URL=https://api.bge-host/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIM=1024

# ===== 可选：仅当前端直连 FastAPI 流式端点时才需要（默认 Java 透传 SSE，不需要）=====
RUOYI_JWT_SECRET=
RUOYI_JWT_ALG=HS512
